# Terraform directories
.terraform/

# Terraform state files
*.tfstate
*.tfstate.*

# Terraform lock file (OPTIONAL: usually you SHOULD commit this)
# Uncomment the next line only if you intentionally want to ignore it
# .terraform.lock.hcl

# Crash logs
crash.log

# Sensitive variable files
*.tfvars
*.tfvars.json

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration files
.terraformrc
terraform.rc

# Kubernetes config (if generated locally)
kubeconfig

# Node (if you use it somewhere in the project)
node_modules/

# Terraform plan files
*.tfplan

# Archives
*.zip

# Images (optional - depends on submission)
*.png

# Local downloaded state (VERY IMPORTANT)
dev.terraform.tfstate

